{
  "name": "obsidian-publishing-manager",
  "version": "0.1.0",
  "description": "Offline, local-first publishing operations for Obsidian",
  "main": "main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run typecheck && npm run check:support && npm run check:forbidden && npm run check:integrations && npm run check:security && node esbuild.config.mjs production && npm run check:offline-bundle && npm run check:package",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run check:conventions && npm run check:test-vault && npm run check:support && npm run check:forbidden && npm run check:integrations && npm run check:security && npm run test && npm run test:offline",
    "check:conventions": "node scripts/check-repository-conventions.mjs",
    "check:forbidden": "node scripts/check-forbidden-apis.mjs",
    "check:integrations": "node scripts/check-integration-boundaries.mjs",
    "check:offline-bundle": "node scripts/verify-offline-runtime.mjs",
    "check:package": "node scripts/audit-release-package.mjs",
    "check:security": "node scripts/check-security-boundaries.mjs",
    "check:support": "node scripts/check-support-policy.mjs",
    "check:test-vault": "node scripts/check-test-vault-workflow.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:offline": "node --import ./scripts/block-network-runtime.mjs ./node_modules/vitest/vitest.mjs run",
    "test:fixtures": "vitest run tests/fixtures.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:vault": "npm run build && node scripts/create-test-vault.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "obsidian",
    "publishing",
    "local-first"
  ],
  "author": "Anthony Fitzpatrick",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "1.8.7",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "4.1.10"
  }
}
